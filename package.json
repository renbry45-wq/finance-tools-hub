{
  "name": "finance-tools-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Finance Tools Hub static site, built with Eleventy. Source in src/, build output in dist/.",
  "scripts": {
    "build": "eleventy",
    "watch": "eleventy --watch",
    "serve": "eleventy --serve",
    "clean": "rm -rf dist",
    "seo:validate": "node scripts/seo-validate.cjs",
    "seo:check-html": "node scripts/seo-check-html.cjs",
    "postinstall": "node -e \"const fs=require('fs');fs.writeFileSync('.git/hooks/pre-push','#!/bin/sh\\nnode scripts/seo-validate.cjs\\nif [ \\$? -ne 0 ]; then exit 1; fi\\n');require('child_process').execSync('chmod +x .git/hooks/pre-push')\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5"
  }
}
