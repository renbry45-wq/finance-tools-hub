bodyHtml: |
  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">How the savings goal calculator works</h2>
      <p class="mt-4 text-slate-600">Enter your savings target and current balance to see how many months you need at your current contribution rate. The calculator uses monthly compound interest, which means interest earned each month is added to your balance and earns interest the following month.</p>
      <div class="mt-6 space-y-4">
        <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-5">
          <p class="font-semibold text-slate-900">If rate = 0: months = (goal − current) ÷ monthly contribution</p>
        </div>
        <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-5">
          <p class="font-semibold text-slate-900">If rate &gt; 0: months = log((goal + PMT/r) ÷ (current + PMT/r)) ÷ log(1 + r)</p>
          <p class="mt-2 text-sm text-slate-600">Where r = annual rate ÷ 12 and PMT = monthly contribution. Accounts for compound growth of both contributions and existing savings.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Common scenarios</h2>
      <div class="mt-5 grid md:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">Emergency fund</h3>
          <p class="mt-2 text-slate-600">How long to save three to six months of expenses at $500 per month in a high-yield savings account?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">Down payment</h3>
          <p class="mt-2 text-slate-600">How long to accumulate a $40,000 house down payment starting with $10,000 saved?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">Travel fund</h3>
          <p class="mt-2 text-slate-600">How many months to reach $5,000 for a trip at $200 per month with no interest?</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-emerald-100 bg-emerald-50 p-6">
      <p class="text-sm text-slate-700"><strong class="text-slate-900">Related reading:</strong> <a class="text-emerald-700 font-medium" href="/articles/can-i-afford-to-go-freelance.html">Can I afford to go freelance? The financial checklist</a></p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Sources and methodology</h2>
      <p class="mt-4 text-slate-600">This calculator is an educational estimate based on standard time-value-of-money formulas. It assumes a fixed interest rate compounded monthly and consistent monthly contributions. Real-world savings may vary due to rate changes, irregular deposits, or fees.</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/methodology.html" class="px-4 py-3 rounded-full bg-slate-900 text-white font-medium">Read methodology</a>
        <a href="/about.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">About the site</a>
        <a href="/author-renato-bryant.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">Author profile</a>
      </div>
    </div>
  </section>
calcScript: |
  function sgFmt(n){return n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});}
  function sgFmtMonths(m){var y=Math.floor(m/12),mo=m%12;if(y===0)return mo+' month'+(mo!==1?'s':'');if(mo===0)return y+' year'+(y!==1?'s':'');return y+' year'+(y!==1?'s':'')+', '+mo+' month'+(mo!==1?'s':'');}
  function sgCalculate(){
    var goal=parseFloat(document.getElementById('sg-goal').value)||0;
    var current=parseFloat(document.getElementById('sg-current').value)||0;
    var monthly=parseFloat(document.getElementById('sg-monthly').value)||0;
    var annualRate=parseFloat(document.getElementById('sg-rate').value)||0;
    var resultEl=document.getElementById('sg-result');
    var breakdownEl=document.getElementById('sg-breakdown');
    if(goal<0||current<0||monthly<0||annualRate<0){resultEl.innerHTML='<p class="text-red-600 font-medium">Inputs cannot be negative.</p>';return;}
    if(goal===0){resultEl.innerHTML='<p class="text-slate-500">Enter a savings goal to calculate.</p>';return;}
    if(current>=goal){resultEl.innerHTML='<div class="rounded-2xl bg-emerald-50 border border-emerald-200 p-6"><p class="text-2xl font-bold text-emerald-700">You\'ve already reached your goal!</p><p class="mt-2 text-slate-600">Your current savings of $'+sgFmt(current)+' meets or exceeds your goal of $'+sgFmt(goal)+'.</p></div>';breakdownEl.hidden=true;return;}
    var remaining=goal-current;
    var r=annualRate/100/12;
    if(monthly===0&&r===0){resultEl.innerHTML='<p class="text-amber-700 font-medium">Add a monthly contribution to calculate your timeline.</p>';return;}
    var months;
    if(r===0){
      months=Math.ceil(remaining/monthly);
    } else if(monthly===0){
      if(current<=0){resultEl.innerHTML='<p class="text-amber-700 font-medium">Add a monthly contribution or a starting balance to calculate.</p>';return;}
      months=Math.ceil(Math.log(goal/current)/Math.log(1+r));
    } else {
      var ratio=(goal+monthly/r)/(current+monthly/r);
      if(ratio<=0){resultEl.innerHTML='<p class="text-red-600 font-medium">Unable to reach goal with these inputs. Try increasing your monthly contribution.</p>';return;}
      months=Math.ceil(Math.log(ratio)/Math.log(1+r));
    }
    if(months>1200){resultEl.innerHTML='<p class="text-amber-700 font-medium">Timeline exceeds 100 years. Consider increasing your monthly contribution or interest rate.</p>';return;}
    var bal=current,totInterest=0,i;
    for(i=0;i<months;i++){var int=bal*r;totInterest+=int;bal=bal+int+monthly;}
    var totContribs=monthly*months;
    var pct=Math.min(100,goal>0?current/goal*100:0);
    resultEl.innerHTML='<div class="grid md:grid-cols-3 gap-4"><div class="result-card bg-emerald-50"><p class="text-sm text-emerald-700">Time to goal</p><p class="text-3xl font-bold text-emerald-700">'+sgFmtMonths(months)+'</p><p class="text-xs text-emerald-600 mt-1">'+months+' month'+(months!==1?'s':'')+'</p></div><div class="result-card"><p class="text-sm text-slate-500">Total contributions</p><p class="text-3xl font-bold">$'+sgFmt(totContribs)+'</p></div><div class="result-card"><p class="text-sm text-slate-500">Interest earned</p><p class="text-3xl font-bold">$'+sgFmt(totInterest)+'</p></div></div><div class="mt-5"><div class="flex justify-between text-xs text-slate-500 mb-1"><span>Current progress toward goal</span><span>'+pct.toFixed(1)+'% of $'+sgFmt(goal)+'</span></div><div class="w-full bg-slate-100 rounded-full h-3"><div class="bg-emerald-500 h-3 rounded-full" style="width:'+pct.toFixed(1)+'%"></div></div></div><div class="mt-4 text-sm text-slate-600">Related tools: <a class="text-emerald-700" href="/retirement-savings-calculator.html">Retirement Savings Calculator</a> and <a class="text-emerald-700" href="/take-home-pay-calculator.html">Take-Home Pay Calculator</a>.</div><div class="mt-5"><button id="sg-toggle-btn" onclick="sgToggleBreakdown()" class="px-5 py-3 rounded-2xl border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 transition">Show annual breakdown</button></div>';
    sgBuildBreakdown(current,monthly,r,months,goal);
    if(window.fthTrack)window.fthTrack('fth_calculate_click',{calculator_slug:'savings-goal-calculator'});
  }
  function sgBuildBreakdown(startBal,monthly,r,totalMonths,goal){
    var wrap=document.getElementById('sg-breakdown');
    var rows=[],bal=startBal,yContribs=0,yInterest=0,m;
    for(m=1;m<=totalMonths;m++){var int=bal*r;yInterest+=int;yContribs+=monthly;bal=bal+int+monthly;if(m%12===0||m===totalMonths){var yr=Math.ceil(m/12);rows.push({yr:yr,bal:bal,yContribs:yContribs,yInterest:yInterest,pct:Math.min(100,goal>0?bal/goal*100:100)});yContribs=0;yInterest=0;}}
    var rowsHtml='';
    for(var j=0;j<rows.length;j++){var row=rows[j];rowsHtml+='<tr><td class="px-4 py-3 text-slate-700">Year '+row.yr+'</td><td class="px-4 py-3 text-right text-slate-700">$'+sgFmt(row.yContribs)+'</td><td class="px-4 py-3 text-right text-slate-700">$'+sgFmt(row.yInterest)+'</td><td class="px-4 py-3 text-right font-medium text-slate-900">$'+sgFmt(row.bal)+'</td><td class="px-4 py-3 text-right text-emerald-700">'+row.pct.toFixed(0)+'%</td></tr>';}
    wrap.innerHTML='<div class="rounded-2xl border border-slate-200 overflow-x-auto"><table class="w-full text-sm"><thead class="bg-slate-50 border-b border-slate-200"><tr><th class="px-4 py-3 text-left font-semibold text-slate-700">Year</th><th class="px-4 py-3 text-right font-semibold text-slate-700">Contributions</th><th class="px-4 py-3 text-right font-semibold text-slate-700">Interest</th><th class="px-4 py-3 text-right font-semibold text-slate-700">Closing Balance</th><th class="px-4 py-3 text-right font-semibold text-slate-700">Progress</th></tr></thead><tbody class="divide-y divide-slate-100">'+rowsHtml+'</tbody></table></div>';
    wrap.hidden=true;
  }
  function sgToggleBreakdown(){
    var wrap=document.getElementById('sg-breakdown');
    var btn=document.getElementById('sg-toggle-btn');
    if(!wrap)return;
    wrap.hidden=!wrap.hidden;
    if(btn)btn.textContent=wrap.hidden?'Show annual breakdown':'Hide annual breakdown';
  }
  ['sg-goal','sg-current','sg-monthly','sg-rate'].forEach(function(id){var el=document.getElementById(id);if(el)el.addEventListener('input',sgCalculate);});
  sgCalculate();
