<section id="all-tools" class="py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-2xl md:text-3xl font-black text-slate-900">Popular Calculators</h2>
