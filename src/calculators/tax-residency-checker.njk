  <section class="max-w-5xl mx-auto px-4 py-12"><div class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8 md:p-10 card-shadow"><div class="max-w-2xl space-y-5"><div><label class="block text-sm font-medium mb-2">Days Spent in Destination Country</label><input id="days" type="number" value="90" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Do you maintain a tax home in your home country?</label><select id="tax-home" class="w-full rounded-2xl border-slate-300 p-4"><option value="yes">Yes</option><option value="no">No</option></select></div><div><label class="block text-sm font-medium mb-2">Do you have a permanent home available abroad?</label><select id="perm-home" class="w-full rounded-2xl border-slate-300 p-4"><option value="no">No</option><option value="yes">Yes</option></select></div><button onclick="calculate()" class="w-full rounded-2xl bg-emerald-600 py-4 font-semibold text-white hover:bg-emerald-700">Check Residency</button></div><div id="result" class="mt-8"></div><div id="decision-state" class="mt-6" hidden><div class="rounded-2xl border p-6" data-decision-state><p class="text-xs uppercase tracking-wide font-semibold" data-state-eyebrow></p><h3 class="mt-2 text-xl font-bold" data-state-label></h3><p class="mt-3 text-slate-700" data-state-body></p><div class="mt-4 rounded-xl bg-white border border-slate-200 p-4"><p class="text-sm font-semibold text-slate-900">Recommended next step</p><p class="mt-1 text-sm text-slate-700" data-next-step-text></p><a class="inline-block mt-2 text-emerald-700 font-medium" data-next-step-link>Open the next calculator →</a></div><p class="mt-4 text-xs text-slate-500">This is an educational estimate. Real outcomes depend on your full situation. Talk to a qualified professional before making major decisions.</p></div></div></div></section>
bodyHtml: |
  <section class="max-w-5xl mx-auto px-4 py-12"><div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow"><h2 class="text-2xl font-bold">Why this tool matters in 2026</h2><p class="mt-4 text-slate-600">Check common remote work tax residency risk triggers such as the 183-day rule, losing your tax home, and maintaining a permanent home abroad. This tool helps remote workers and digital nomads identify situations that may justify professional tax advice before or during a move. Good planning works best when you connect this page with the rest of your workflow on Finance Tools Hub.</p></div></section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">What this tool is designed to check</h2>
      <p class="mt-4 text-slate-600">This page is designed to help remote workers and digital nomads identify whether their facts may create tax residency risk in another country. It focuses on common screening questions rather than detailed legal analysis, so users can decide whether a formal tax review is needed.</p>
      <p class="mt-4 text-slate-600">A result from this page should be treated as a warning signal, not a formal determination. Tax residency can depend on country-specific rules, treaty provisions, center-of-vital-interests tests, and other facts that go far beyond one calculator.</p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Why the 183-day rule matters</h2>
      <p class="mt-4 text-slate-600">The 183-day rule is one of the most recognized starting points in cross-border tax discussions, which is why it appears prominently in this checker. But it is only one signal. Some countries use additional tests that look at your tax home, permanent home, family connections, business presence, or center of economic interests.</p>
      <p class="mt-4 text-slate-600">That means a person may face tax residency risk even below 183 days, or avoid residency in some cases above that threshold depending on the facts and applicable treaty rules.</p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">How to read the result</h2>
      <div class="mt-5 grid md:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">Low</h3>
          <p class="mt-2 text-slate-600">Low means the simplified facts entered here do not immediately suggest the most common residency trigger, but it does not rule out country-specific issues.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">Moderate</h3>
          <p class="mt-2 text-slate-600">Moderate means you may be approaching a common threshold or your facts could justify closer review before you continue working abroad.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">High</h3>
          <p class="mt-2 text-slate-600">High means your situation may create a meaningful tax residency risk and should usually be reviewed with a qualified professional.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Common scenarios</h2>
      <div class="mt-5 grid md:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The long-stay nomad</h3>
          <p class="mt-2 text-slate-600">I have been working remotely in one country for more than four months. At what point could my days abroad create a tax issue?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The freelancer losing tax home</h3>
          <p class="mt-2 text-slate-600">What happens if I no longer maintain a tax home in my original country while also staying abroad for long periods?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The remote worker with a permanent base</h3>
          <p class="mt-2 text-slate-600">Could I face higher residency risk if I keep an apartment or long-term home available in the country where I work remotely?</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-emerald-100 bg-emerald-50 p-6">
      <p class="text-sm text-slate-700"><strong class="text-slate-900">Related reading:</strong> <a class="text-emerald-700 font-medium" href="/articles/183-day-rule-remote-workers.html">What the 183-day rule means for remote workers</a></p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Sources and limitations</h2>
      <p class="mt-4 text-slate-600">This tool is an educational residency-risk screen. It is not tax advice, legal advice, or a treaty analysis. Country-specific rules vary widely.</p>
      <ul class="mt-4 list-disc pl-6 text-slate-600 space-y-2">
        <li>The calculator uses broad, common triggers such as the 183-day rule and tax-home concepts.</li>
        <li>Permanent home, center of vital interests, treaty tie-breakers, and local filing obligations can materially change the outcome.</li>
        <li>Use the <a class="text-emerald-700 font-medium" href="/methodology.html">Methodology page</a> and consult a tax professional for real cross-border decisions.</li>
      </ul>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/methodology.html" class="px-4 py-3 rounded-full bg-slate-900 text-white font-medium">Read methodology</a>
        <a href="/about.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">About the site</a>
        <a href="/author-renato-bryant.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">Author profile</a>
      </div>
    </div>
  </section>


calcScript: |
  // Default inputs (days=90, tax-home=yes, perm-home=no) land on: lower-watch (emerald). Tier mapping: Low → lower-watch, Moderate → review-recommended, High → higher-residency-risk. The "Read more on the 183-day rule article" link for the Moderate and High states points to /articles/183-day-rule-remote-workers.html (Week 3 article).
  function calculate(){ const days=parseFloat(document.getElementById('days').value)||0, taxHome=document.getElementById('tax-home').value, home=document.getElementById('perm-home').value; let risk='Low'; if(days>=183) risk='High'; else if(days>=120) risk='Moderate'; let msg=risk==='High'?'You may become tax resident after 183 days or similar local tests.':risk==='Moderate'?'You are approaching a common tax residency threshold.':'Your days count is below the most common threshold, but other local rules may still apply.'; if(taxHome==='no'&&home==='yes') msg += ' Losing your tax home while keeping a permanent home abroad increases risk.'; const result={'Days in Country':days,'Maintains Tax Home':taxHome,'Permanent Home Abroad':home,'Risk Level':risk,'Summary':msg};
   document.getElementById('result').innerHTML=`<div class="grid md:grid-cols-2 gap-4"><div class="result-card bg-emerald-50"><p class="text-sm text-emerald-700">Risk level</p><p class="text-4xl font-bold text-emerald-700">${risk}</p></div><div class="result-card"><p class="text-sm text-slate-500">Summary</p><p class="text-base mt-2">${msg}</p></div></div><div class="mt-4 text-slate-600">Related tools: <a class="text-emerald-700" href="gig-tax-optimizer.html">Gig Tax Optimizer</a> and <a class="text-emerald-700" href="nomad-health-insurance-estimator.html">Nomad Health Insurance Estimator</a>.</div><div class="flex flex-wrap gap-3 mt-6"><button class="px-5 py-3 rounded-2xl bg-slate-900 text-white" onclick='downloadResultPDF("Tax Residency Checker", ${JSON.stringify(result)})'>Download PDF</button><button class="px-5 py-3 rounded-2xl bg-emerald-600 text-white" onclick='emailResult("Tax Residency Checker", ${JSON.stringify(result)})'>Send by Email</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("X","Tax Residency Checker")'>X</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("Facebook","Tax Residency Checker")'>Facebook</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("LinkedIn","Tax Residency Checker")'>LinkedIn</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("WhatsApp","Tax Residency Checker")'>WhatsApp</button></div>`;
   if (risk === 'Low') setDecisionState('lower-watch', 'emerald', 'Lower watch', "Your answers suggest a lower watch on accidentally triggering tax residency in another country. This is general guidance — official rules vary by country and treaty.", "If you're planning a move, model the cost with the Digital Nomad Calculator.", '/digital-nomad-calculator.html');
   else if (risk === 'Moderate') setDecisionState('review-recommended', 'amber', 'Review recommended', "Your answers suggest some tax residency risk worth reviewing. The 183-day rule is one of several tests — consult a cross-border tax professional.", "Read more on the 183-day rule article.", '/articles/183-day-rule-remote-workers.html');
   else setDecisionState('higher-residency-risk', 'red', 'Higher residency risk', "Your answers suggest a higher risk of triggering tax residency in another country. Specific rules vary — this is not a substitute for professional cross-border tax advice.", "Read more on the 183-day rule article.", '/articles/183-day-rule-remote-workers.html');
   }
  function setDecisionState(stateKey, color, label, body, nextText, nextHref) {
    const wrap = document.getElementById('decision-state');
    if (!wrap) return;
    const card = wrap.querySelector('[data-decision-state]');
    card.className = 'rounded-2xl border p-6';
    const colorMap = { emerald: 'bg-emerald-100 border-emerald-300', slate: 'bg-slate-100 border-slate-300', amber: 'bg-amber-100 border-amber-300', red: 'bg-red-100 border-red-300' };
    card.classList.add(...colorMap[color].split(' '));
    card.dataset.state = stateKey;
    card.querySelector('[data-state-eyebrow]').textContent = 'Decision state';
    card.querySelector('[data-state-label]').textContent = label;
    card.querySelector('[data-state-body]').textContent = body;
    card.querySelector('[data-next-step-text]').textContent = nextText;
    const link = card.querySelector('[data-next-step-link]');
    link.href = nextHref;
    wrap.hidden = false;
  }
