calcBody: |
  <section class="max-w-5xl mx-auto px-4 py-12"><div class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8 md:p-10 card-shadow"><div class="max-w-2xl space-y-5"><div><label class="block text-sm font-medium mb-2">Age</label><input id="age" type="number" value="30" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Family Size</label><select id="family" class="w-full rounded-2xl border-slate-300 p-4"><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option></select></div><div><label class="block text-sm font-medium mb-2">Destination Country</label><select id="country" class="w-full rounded-2xl border-slate-300 p-4"><option>Portugal</option><option>Spain</option><option>Thailand</option><option>Mexico</option><option>Indonesia</option><option>Croatia</option><option>Estonia</option><option>Malaysia</option><option>Costa Rica</option><option>Georgia</option><option>Vietnam</option><option>USA</option><option>UK</option><option>Germany</option><option>Australia</option><option>Other</option></select></div><div><label class="block text-sm font-medium mb-2">Coverage Level</label><select id="level" class="w-full rounded-2xl border-slate-300 p-4"><option value="basic">Basic</option><option value="standard">Standard</option><option value="premium">Premium</option></select></div><button onclick="calculate()" class="w-full rounded-2xl bg-emerald-600 py-4 font-semibold text-white hover:bg-emerald-700">Estimate Insurance</button></div><div id="result" class="mt-8"></div></div></section>
bodyHtml: |
  <section class="max-w-5xl mx-auto px-4 py-12"><div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow"><h2 class="text-2xl font-bold">Why this tool matters in 2026</h2><p class="mt-4 text-slate-600">Estimate monthly and annual digital nomad medical coverage costs by age, family size, destination, and coverage level. This nomad insurance estimator helps remote workers compare likely premiums abroad versus home-country private insurance costs. Good planning works best when you connect this page with the rest of your workflow on Finance Tools Hub.</p></div></section>
    
  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">What this calculator does</h2>
      <p class="mt-4 text-slate-600">This page estimates digital nomad health insurance cost based on broad pricing assumptions tied to age, family size, destination country, and coverage level. It is designed to help users understand whether healthcare cost is a minor budget line or a major relocation factor.</p>
      <p class="mt-4 text-slate-600">It is especially useful when paired with the <a class="text-emerald-700 font-medium" href="/digital-nomad-calculator.html">Digital Nomad Calculator</a>, because health insurance is one of the most commonly underestimated costs in international relocation planning.</p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">What affects your premium estimate</h2>
      <div class="mt-5 grid md:grid-cols-2 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">Age and family size</h3>
          <p class="mt-2 text-slate-600">Premium assumptions rise with age and usually increase materially when you insure a partner or children instead of one adult.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">Country and coverage level</h3>
          <p class="mt-2 text-slate-600">Destination country affects the underlying benchmark, while basic, standard, and premium coverage levels create different expected price bands.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">How to use this estimator well</h2>
      <ol class="mt-5 list-decimal pl-6 text-slate-600 space-y-3">
        <li>Choose the destination country you are seriously considering, not just a tentative short list.</li>
        <li>Select a coverage level that matches your actual risk tolerance and travel style.</li>
        <li>Review the estimated monthly premium and compare it with home-country private insurance assumptions.</li>
        <li>Then include the result in your broader move budget with the <a class="text-emerald-700 font-medium" href="/digital-nomad-calculator.html">Digital Nomad Calculator</a> and <a class="text-emerald-700 font-medium" href="/cost-of-living-comparison.html">Cost of Living Comparison</a>.</li>
      </ol>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Common scenarios</h2>
      <div class="mt-5 grid md:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The solo nomad</h3>
          <p class="mt-2 text-slate-600">How much should I budget for health insurance if I am moving alone and only need standard international coverage?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The family relocation</h3>
          <p class="mt-2 text-slate-600">What happens to monthly health insurance cost if I relocate with a partner or children instead of moving solo?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The premium coverage planner</h3>
          <p class="mt-2 text-slate-600">How much more expensive is a premium nomad policy versus a basic plan in a higher-cost destination?</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Sources and methodology</h2>
      <p class="mt-4 text-slate-600">This page is an educational estimate built from broad benchmark assumptions. Actual premiums can vary significantly by insurer, underwriting rules, pre-existing conditions, destination rules, deductible choices, and benefit design.</p>
      <ul class="mt-4 list-disc pl-6 text-slate-600 space-y-2">
        <li>Coverage benchmarks are for planning, not binding quotes.</li>
        <li>Home-country comparisons are simplified and should not be treated as insurer offers.</li>
        <li>Use the <a class="text-emerald-700 font-medium" href="/methodology.html">Methodology page</a> to understand how Finance Tools Hub approaches assumptions and estimate design.</li>
      </ul>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/methodology.html" class="px-4 py-3 rounded-full bg-slate-900 text-white font-medium">Read methodology</a>
        <a href="/about.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">About the site</a>
        <a href="/author-renato-bryant.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">Author profile</a>
      </div>
    </div>
  </section>


calcScript: |
  function calculate(){ const age=parseFloat(document.getElementById('age').value)||0, family=parseInt(document.getElementById('family').value)||1, country=document.getElementById('country').value, level=document.getElementById('level').value; const rates={basic:{0:100,30:120,40:150,50:200,65:300},standard:{0:140,30:160,40:200,50:250,65:350},premium:{0:200,30:230,40:280,50:350,65:450}}; const mult={Portugal:1,Spain:1,Thailand:.7,Mexico:.8,Indonesia:.7,Croatia:1,Estonia:.9,Malaysia:.8,'Costa Rica':.9,Georgia:.7,Vietnam:.7,USA:1.4,UK:1.3,Germany:1.1,Australia:1.4,Other:1.2}; const fam={1:1,2:1.8,3:2.5,4:3.1}[family]||1; let bracket=age<30?0:age<40?30:age<50?40:age<65?50:65; const base=rates[level][bracket], monthly=base*(mult[country]||1)*fam, annual=monthly*12, home=base*1.4*fam, diff=home-monthly; const result={'Age':age,'Family Size':family,'Destination Country':country,'Coverage Level':level,'Monthly Premium':'$'+monthly.toFixed(2),'Annual Cost':'$'+annual.toFixed(2),'Home Premium Estimate':'$'+home.toFixed(2),'Difference vs Home':(diff>=0?'+':'-')+'$'+Math.abs(diff).toFixed(2)};
   document.getElementById('result').innerHTML=`<div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4"><div class="result-card bg-emerald-50"><p class="text-sm text-emerald-700">Monthly premium</p><p class="text-4xl font-bold text-emerald-700">$${monthly.toFixed(2)}</p></div><div class="result-card"><p class="text-sm text-slate-500">Annual cost</p><p class="text-4xl font-bold">$${annual.toFixed(2)}</p></div><div class="result-card"><p class="text-sm text-slate-500">Home premium</p><p class="text-4xl font-bold">$${home.toFixed(2)}</p></div><div class="result-card"><p class="text-sm text-slate-500">Difference</p><p class="text-4xl font-bold ${diff>=0?'text-emerald-700':'text-red-600'}">${diff>=0?'+':'-'}$${Math.abs(diff).toFixed(2)}</p></div></div><div class="mt-4 text-slate-600">Use this with the <a class="text-emerald-700" href="digital-nomad-calculator.html">Digital Nomad Calculator</a> for a more complete relocation budget.</div><div class="flex flex-wrap gap-3 mt-6"><button class="px-5 py-3 rounded-2xl bg-slate-900 text-white" onclick='downloadResultPDF("Nomad Health Insurance Estimator", ${JSON.stringify(result)})'>Download PDF</button><button class="px-5 py-3 rounded-2xl bg-emerald-600 text-white" onclick='emailResult("Nomad Health Insurance Estimator", ${JSON.stringify(result)})'>Send by Email</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("X","Nomad Health Insurance Estimator")'>X</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("Facebook","Nomad Health Insurance Estimator")'>Facebook</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("LinkedIn","Nomad Health Insurance Estimator")'>LinkedIn</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("WhatsApp","Nomad Health Insurance Estimator")'>WhatsApp</button></div>`;
   }
---
