  function calculate(){
   const income=parseFloat(document.getElementById('income').value)||0, status=document.getElementById('status').value; let tax=0;
   if(status==='single'){ if(income<=11600) tax=income*.1; else if(income<=47150) tax=1160+(income-11600)*.12; else if(income<=100525) tax=5410+(income-47150)*.22; else if(income<=191950) tax=17168+(income-100525)*.24; else if(income<=243725) tax=39110+(income-191950)*.32; else if(income<=609350) tax=55678+(income-243725)*.35; else tax=183647+(income-609350)*.37; }
   else if(status==='married'){ if(income<=23200) tax=income*.1; else if(income<=94300) tax=2320+(income-23200)*.12; else if(income<=201050) tax=10820+(income-94300)*.22; else if(income<=383900) tax=34336+(income-201050)*.24; else if(income<=487450) tax=78220+(income-383900)*.32; else if(income<=731200) tax=111358+(income-487450)*.35; else tax=196669+(income-731200)*.37; }
   else { if(income<=16550) tax=income*.1; else if(income<=63100) tax=1655+(income-16550)*.12; else if(income<=100500) tax=7241+(income-63100)*.22; else if(income<=191950) tax=15469+(income-100500)*.24; else if(income<=243700) tax=37417+(income-191950)*.32; else if(income<=609350) tax=53977+(income-243700)*.35; else tax=181954+(income-609350)*.37; }
   const result={'Filing Status':status,'Taxable Income':'$'+income.toFixed(2),'Estimated Federal Tax':'$'+tax.toFixed(2),'Effective Tax Rate':((tax/income||0)*100).toFixed(1)+'%'};
   document.getElementById('result').innerHTML=`<div class="grid md:grid-cols-2 gap-4"><div class="result-card bg-emerald-50"><p class="text-sm text-emerald-700">Estimated federal tax</p><p class="text-4xl font-bold text-emerald-700">$${tax.toFixed(2)}</p></div><div class="result-card"><p class="text-sm text-slate-500">Effective tax rate</p><p class="text-4xl font-bold">${((tax/income||0)*100).toFixed(1)}%</p></div></div><div class="flex flex-wrap gap-3 mt-6"><button class="px-5 py-3 rounded-2xl bg-slate-900 text-white" onclick='downloadResultPDF("Tax Bracket Calculator", ${JSON.stringify(result)})'>Download PDF</button><button class="px-5 py-3 rounded-2xl bg-emerald-600 text-white" onclick='emailResult("Tax Bracket Calculator", ${JSON.stringify(result)})'>Send by Email</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("X","Tax Bracket Calculator")'>X</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("Facebook","Tax Bracket Calculator")'>Facebook</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("LinkedIn","Tax Bracket Calculator")'>LinkedIn</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("WhatsApp","Tax Bracket Calculator")'>WhatsApp</button></div>`;
   if (window.fthTrack) window.fthTrack('fth_calculate_click', { calculator_slug: document.body.dataset.calculatorSlug || '' });
   }
