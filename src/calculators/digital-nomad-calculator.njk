bodyHtml: |
  <section class="max-w-5xl mx-auto px-4 py-12"><div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow"><h2 class="text-2xl font-bold">Why this tool matters in 2026</h2><p class="mt-4 text-slate-600">Estimate monthly living costs, one-time setup expenses, visa fees, home-vs-abroad tax comparison, and break-even timing. This digital nomad calculator is especially helpful for remote workers comparing countries before relocating abroad. Good planning works best when you connect this page with the rest of your workflow on Finance Tools Hub.</p></div></section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">What this calculator does</h2>
      <p class="mt-4 text-slate-600">This digital nomad calculator estimates the total financial impact of relocating abroad by combining recurring living costs with one-time setup costs. It helps users compare a destination against their current income, expected tax assumptions, and family size so they can judge whether a move is financially realistic.</p>
      <p class="mt-4 text-slate-600">Unlike a simple travel budget sheet, this page is designed for medium-term relocation planning. It accounts for the difference between monthly cash burn and upfront costs such as visa fees, making it more useful for remote workers who need to evaluate sustainability, not just affordability.</p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">What costs are included</h2>
      <div class="mt-5 grid md:grid-cols-2 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">Monthly costs</h3>
          <p class="mt-2 text-slate-600">Rent, food, internet, coworking, transport, and health insurance are treated as recurring monthly costs that affect sustainability after you move.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold text-slate-900">One-time costs</h3>
          <p class="mt-2 text-slate-600">Visa fees and other setup costs are treated separately so you can estimate the capital needed to get started before the move begins to pay for itself.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">How to use this calculator in a relocation workflow</h2>
      <ol class="mt-5 list-decimal pl-6 text-slate-600 space-y-3">
        <li>Choose a destination country and review the suggested cost defaults.</li>
        <li>Adjust monthly costs to match your likely lifestyle rather than relying only on city averages.</li>
        <li>Enter your income and family size to see whether the move remains sustainable.</li>
        <li>Review break-even timing and then compare cities using the <a class="text-emerald-700 font-medium" href="/cost-of-living-comparison.html">Cost of Living Comparison</a>.</li>
        <li>Check residency and insurance implications with the <a class="text-emerald-700 font-medium" href="/tax-residency-checker.html">Tax Residency Checker</a> and <a class="text-emerald-700 font-medium" href="/nomad-health-insurance-estimator.html">Nomad Health Insurance Estimator</a>.</li>
      </ol>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Common scenarios</h2>
      <div class="mt-5 grid md:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The solo freelancer</h3>
          <p class="mt-2 text-slate-600">Can I afford Portugal or Spain on $6,000 a month after taxes if I work independently and need coworking space?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The remote employee</h3>
          <p class="mt-2 text-slate-600">How much would I spend per month living in Thailand or Malaysia if I keep my current salary and want a comfort lifestyle?</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <h3 class="font-semibold">The family relocation planner</h3>
          <p class="mt-2 text-slate-600">What is the likely monthly cost and break-even period if I move abroad with a partner or children instead of relocating alone?</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
      <h2 class="text-2xl font-bold">Sources and methodology</h2>
      <p class="mt-4 text-slate-600">This calculator is an educational estimate. Actual costs vary by city, neighborhood, visa route, insurance provider, family composition, and tax situation.</p>
      <ul class="mt-4 list-disc pl-6 text-slate-600 space-y-2">
        <li>Country cost defaults are planning benchmarks, not guaranteed market prices.</li>
        <li>Visa and tax assumptions should be checked against official government and tax authority sources before a move.</li>
        <li>Use the <a class="text-emerald-700 font-medium" href="/methodology.html">Methodology page</a> to understand how Finance Tools Hub approaches calculator design and assumptions.</li>
      </ul>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/methodology.html" class="px-4 py-3 rounded-full bg-slate-900 text-white font-medium">Read methodology</a>
        <a href="/about.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">About the site</a>
        <a href="/author-renato-bryant.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">Author profile</a>
      </div>
    </div>
  </section>


calcScript: |
  // Default inputs (Portugal, income=$6000, family=1, lifestyle=budget, monthly-home blank) → no decision state shown; "Enter your current home cost..." note shown instead. monthlyAbroad ≈ $1,533. Filling in monthly-home unlocks the 5-state pctDelta thresholds.
  const nomadData={Portugal:{rent:800,food:350,internet:40,cowork:200,transport:80,health:150,visa:500},Spain:{rent:900,food:450,internet:50,cowork:250,transport:100,health:150,visa:400},Thailand:{rent:600,food:300,internet:30,cowork:150,transport:50,health:100,visa:300},Mexico:{rent:700,food:350,internet:40,cowork:150,transport:80,health:100,visa:500},Indonesia:{rent:500,food:250,internet:20,cowork:100,transport:60,health:120,visa:400},Croatia:{rent:800,food:350,internet:40,cowork:200,transport:80,health:150,visa:350},Estonia:{rent:750,food:400,internet:40,cowork:200,transport:70,health:140,visa:200},Malaysia:{rent:550,food:250,internet:30,cowork:100,transport:60,health:120,visa:400},'Costa Rica':{rent:800,food:350,internet:40,cowork:150,transport:70,health:130,visa:500},Georgia:{rent:650,food:300,internet:30,cowork:100,transport:60,health:110,visa:200},Other:{rent:1000,food:400,internet:50,cowork:200,transport:100,health:150,visa:500}};
  function defaults(){ const c=document.getElementById('country').value, d=nomadData[c]||nomadData.Other; ['rent','food','internet','cowork','transport','health','visa'].forEach(k=>document.getElementById(k).value=d[k]); }
  function calculate(){ const income=parseFloat(document.getElementById('income').value)||0, family=parseInt(document.getElementById('family').value)||1, lifestyle=document.getElementById('lifestyle').value, country=document.getElementById('country').value; const fm={1:1,2:1.8,3:2.5,4:3.1}[family]||1, lm={budget:.9,comfort:1,premium:1.3}[lifestyle]||1; const monthly=(['rent','food','internet','cowork','transport','health'].reduce((s,k)=>s+(parseFloat(document.getElementById(k).value)||0),0))*fm*lm; const visa=(parseFloat(document.getElementById('visa').value)||0)*family; const homeTax=income*.25, abroadTax=income*.15; const savings=(income*.7+homeTax/12)-(monthly+abroadTax/12); const breakEven=savings>0?(visa/savings):Infinity; const score=Math.max(0,Math.min(100,Math.round(100-(monthly/(income||1))*50-(breakEven===Infinity?0:breakEven)))); const result={'Country':country,'Monthly Cost Abroad':'$'+(monthly+abroadTax/12).toFixed(2),'One-Time Setup Cost':'$'+visa.toFixed(2),'Tax Savings vs Home':'$'+(homeTax-abroadTax).toFixed(2),'Break-Even Months':breakEven===Infinity?'N/A':breakEven.toFixed(1),'Recommended Score':score+'/100'};
   document.getElementById('result').innerHTML=`<div class="grid md:grid-cols-3 gap-4"><div class="result-card bg-emerald-50"><p class="text-sm text-emerald-700">Monthly cost abroad</p><p class="text-4xl font-bold text-emerald-700">$${(monthly+abroadTax/12).toFixed(2)}</p></div><div class="result-card"><p class="text-sm text-slate-500">One-time setup</p><p class="text-4xl font-bold">$${visa.toFixed(2)}</p></div><div class="result-card"><p class="text-sm text-slate-500">Break-even months</p><p class="text-4xl font-bold">${breakEven===Infinity?'N/A':breakEven.toFixed(1)}</p></div></div><div class="mt-4 text-slate-600">Use the <a class="text-emerald-700" href="cost-of-living-comparison.html">Cost of Living Comparison</a> and <a class="text-emerald-700" href="break-even-savings-calculator.html">Break-Even Savings Calculator</a> to go deeper.</div><div class="flex flex-wrap gap-3 mt-6"><button class="px-5 py-3 rounded-2xl bg-slate-900 text-white" onclick='downloadResultPDF("Digital Nomad Calculator", ${JSON.stringify(result)})'>Download PDF</button><button class="px-5 py-3 rounded-2xl bg-emerald-600 text-white" onclick='emailResult("Digital Nomad Calculator", ${JSON.stringify(result)})'>Send by Email</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("X","Digital Nomad Calculator")'>X</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("Facebook","Digital Nomad Calculator")'>Facebook</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("LinkedIn","Digital Nomad Calculator")'>LinkedIn</button><button class="px-4 py-3 rounded-2xl border" onclick='shareUrl("WhatsApp","Digital Nomad Calculator")'>WhatsApp</button></div>`;
   const monthlyAbroad = monthly + abroadTax/12;
   const monthlyHomeRaw = parseFloat(document.getElementById('monthly-home').value);
   const monthlyHome = (isFinite(monthlyHomeRaw) && monthlyHomeRaw > 0) ? monthlyHomeRaw : null;
   const note = document.getElementById('home-cost-note');
   const wrap = document.getElementById('decision-state');
   if (monthlyHome === null) { if (note) note.hidden = false; if (wrap) wrap.hidden = true; return; }
   if (note) note.hidden = true;
   const pctDelta = (monthlyAbroad - monthlyHome) / monthlyHome;
   if (pctDelta <= -0.20) setDecisionState('materially-cheaper-abroad', 'emerald', 'Materially cheaper abroad', "Your modeled monthly cost abroad is at least 20% lower than your current home cost. The lifestyle and tax implications matter too — see the Tax Residency Checker.", "Use the Break-Even Savings Calculator to estimate how long it takes to recover relocation costs.", '/break-even-savings-calculator.html');
   else if (pctDelta <= -0.10) setDecisionState('meaningfully-cheaper-abroad', 'emerald', 'Meaningfully cheaper abroad', "Your modeled monthly cost abroad is roughly 10–20% lower than your current home cost. There's a real cost gap, but make sure to factor in insurance, taxes, and one-time setup before deciding.", "Use the Break-Even Savings Calculator to estimate how long it takes to recover relocation costs.", '/break-even-savings-calculator.html');
   else if (pctDelta < 0.10) setDecisionState('roughly-comparable', 'slate', 'Roughly comparable', "Your modeled monthly cost abroad is within about 10% of your current home cost. The decision likely depends on lifestyle, taxes, and insurance — not headline cost.", "Compare specific cities with the Cost of Living Comparison.", '/cost-of-living-comparison.html');
   else if (pctDelta < 0.20) setDecisionState('meaningfully-more-expensive-abroad', 'amber', 'Meaningfully more expensive abroad', "Your modeled monthly cost abroad is roughly 10–20% higher than your current home cost. The move can still make sense for non-financial reasons, but the headline cost is not in your favor.", "Try the Cost of Living Comparison to see if a different destination changes the math.", '/cost-of-living-comparison.html');
   else setDecisionState('materially-more-expensive-abroad', 'amber', 'Materially more expensive abroad', "Your modeled monthly cost abroad is at least 20% higher than your current home cost. Lifestyle, taxes, or visa benefits would need to outweigh a meaningful cost gap.", "Try the Cost of Living Comparison to see if a different destination changes the math.", '/cost-of-living-comparison.html');
   }
  document.addEventListener('DOMContentLoaded', defaults);
  function setDecisionState(stateKey, color, label, body, nextText, nextHref) {
    const wrap = document.getElementById('decision-state');
    if (!wrap) return;
    const card = wrap.querySelector('[data-decision-state]');
    card.className = 'rounded-2xl border p-6';
    const colorMap = { emerald: 'bg-emerald-50 border-emerald-200', slate: 'bg-slate-50 border-slate-200', amber: 'bg-amber-50 border-amber-200', red: 'bg-red-50 border-red-200' };
    card.classList.add(...colorMap[color].split(' '));
    card.dataset.state = stateKey;
    card.querySelector('[data-state-eyebrow]').textContent = 'Decision state';
    card.querySelector('[data-state-label]').textContent = label;
    card.querySelector('[data-state-body]').textContent = body;
    card.querySelector('[data-next-step-text]').textContent = nextText;
    const link = card.querySelector('[data-next-step-link]');
    link.href = nextHref;
    wrap.hidden = false;
  }
