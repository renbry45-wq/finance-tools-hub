calcBody: |
  <section class="max-w-5xl mx-auto px-4 py-12"><div class="rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8 md:p-10 card-shadow"><div class="grid md:grid-cols-2 gap-8"><div class="space-y-5"><div><label class="block text-sm font-medium mb-2">Destination Country</label><select id="country" onchange="defaults()" class="w-full rounded-2xl border-slate-300 p-4"><option>Portugal</option><option>Spain</option><option>Thailand</option><option>Mexico</option><option>Indonesia</option><option>Croatia</option><option>Estonia</option><option>Malaysia</option><option>Costa Rica</option><option>Georgia</option><option>Other</option></select></div><div><label class="block text-sm font-medium mb-2">Current Monthly Income ($)</label><input id="income" type="number" value="6000" class="w-full rounded-2xl border-slate-300 p-4"></div><div class="grid grid-cols-2 gap-4"><div><label class="block text-sm font-medium mb-2">Family Size</label><select id="family" class="w-full rounded-2xl border-slate-300 p-4"><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option></select></div><div><label class="block text-sm font-medium mb-2">Lifestyle</label><select id="lifestyle" class="w-full rounded-2xl border-slate-300 p-4"><option value="budget">Budget</option><option value="comfort">Comfort</option><option value="premium">Premium</option></select></div></div></div><div class="space-y-5"><div class="grid grid-cols-2 gap-4"><div><label class="block text-sm font-medium mb-2">Rent</label><input id="rent" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Food</label><input id="food" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Internet</label><input id="internet" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Coworking</label><input id="cowork" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Transport</label><input id="transport" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div><label class="block text-sm font-medium mb-2">Health Insurance</label><input id="health" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div class="col-span-2"><label class="block text-sm font-medium mb-2">Visa Fees (one-time)</label><input id="visa" type="number" class="w-full rounded-2xl border-slate-300 p-4"></div><div class="col-span-2"><label class="block text-sm font-medium mb-2">Current Monthly Cost at Home ($) — optional</label><input id="monthly-home" type="number" placeholder="Leave blank to skip the comparison" class="w-full rounded-2xl border-slate-300 p-4"></div></div><button onclick="calculate()" class="w-full rounded-2xl bg-emerald-600 py-4 font-semibold text-white hover:bg-emerald-700">Calculate Costs</button></div></div><div id="result" class="mt-8"></div><p id="home-cost-note" class="mt-4 text-sm text-slate-500" hidden>Enter your current home cost above to see how this compares.</p><div id="decision-state" class="mt-6" hidden><div class="rounded-2xl border p-6" data-decision-state><p class="text-xs uppercase tracking-wide font-semibold" data-state-eyebrow></p><h3 class="mt-2 text-xl font-bold" data-state-label></h3><p class="mt-3 text-slate-700" data-state-body></p><div class="mt-4 rounded-xl bg-white border border-slate-200 p-4"><p class="text-sm font-semibold text-slate-900">Recommended next step</p><p class="mt-1 text-sm text-slate-700" data-next-step-text></p><a class="inline-block mt-2 text-emerald-700 font-medium" data-next-step-link>Open the next calculator →</a></div><p class="mt-4 text-xs text-slate-500">This is an educational estimate. Real outcomes depend on your full situation. Talk to a qualified professional before making major decisions.</p></div></div></div></secti