{# Renders the 5-card "Start Here" entry-point grid from src/_data/startHere.json.
   Per Week 1 brief: each card uses an emerald-50 letter-fallback circle as a
   uniform stand-in for the `icon` hint (no icon library, no inline SVG). #}
<section id="start-here" class="max-w-6xl mx-auto px-4 py-14">
  <div class="mb-8">
    <h2 class="text-3xl font-bold">Start Here</h2>
    <p class="mt-2 text-slate-600">Pick the question you're trying to answer.</p>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
    {%- for entry in startHere %}
    {%- set letter = "" %}
    {%- if entry.icon == "briefcase" %}{% set letter = "C" %}
    {%- elif entry.icon == "calculator" %}{% set letter = "F" %}
    {%- elif entry.icon == "globe" %}{% set letter = "M" %}
    {%- elif entry.icon == "card" %}{% set letter = "D" %}
    {%- elif entry.icon == "trending-up" %}{% set letter = "R" %}
    {%- else %}{% set letter = entry.label | first %}
    {%- endif %}
    <a href="{{ entry.url }}" class="group rounded-2xl border border-slate-200 bg-white p-5 card-shadow hover:-translate-y-0.5 transition flex flex-col items-start gap-3 h-full" data-entry-label="{{ entry.label }}">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-emerald-50 text-emerald-700 font-bold text-base">{{ letter }}</span>
      <span class="text-sm font-semibold text-slate-900 group-hover:text-emerald-700 leading-snug">{{ entry.label }}</span>
      <span class="text-emerald-700 text-sm mt-auto">→</span>
    </a>
    {%- endfor %}
  </div>
</section>
