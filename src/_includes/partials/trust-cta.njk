{# Trust CTA + author box reused on calculator pages. The calling page provides
   `sourcesNotes` (list of <li> contents) and optional `methodologyExtra` text. #}

<section class="max-w-5xl mx-auto px-4 py-4">
  <div class="rounded-3xl border border-slate-200 bg-white p-8 card-shadow">
    <h2 class="text-2xl font-bold">Sources and methodology</h2>
    {% if sourcesIntro %}<p class="mt-4 text-slate-600">{{ sourcesIntro }}</p>{% endif %}
    {% if sourcesNotes %}
    <ul class="mt-4 list-disc pl-6 text-slate-600 space-y-2">
      {%- for note in sourcesNotes %}
      <li>{{ note | safe }}</li>
      {%- endfor %}
      <li>Use the <a class="text-emerald-700 font-medium" href="/methodology.html">Methodology page</a> to review how Finance Tools Hub approaches assumptions and transparency.</li>
    </ul>
    {% endif %}
    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/methodology.html" class="px-4 py-3 rounded-full bg-slate-900 text-white font-medium">Read methodology</a>
      <a href="/about.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">About the site</a>
      <a href="/author-renato-bryant.html" class="px-4 py-3 rounded-full border border-slate-300 text-slate-800 font-medium">Author profile</a>
    </div>
  </div>
</section>

<section class="max-w-5xl mx-auto px-4 py-4">
  <div class="rounded-3xl border border-emerald-100 bg-emerald-50 p-8 card-shadow">
    <h2 class="text-2xl font-bold">Created by {{ site.author.name }}</h2>
    <p class="mt-4 text-slate-700">Finance Tools Hub calculators are maintained by {{ site.author.name }}, whose background includes management, budgeting, compliance, and operational oversight. The site is designed to help users translate gross numbers into more practical planning decisions.</p>
    <p class="mt-4 text-slate-700">Last updated: {{ lastUpdated or site.lastUpdated }}.</p>
  </div>
</section>
