{# Related calculators row. The calling page provides `relatedKeys`
   (an array of calculator keys from calculators.json) and an optional
   `relatedIntro` line. #}
<section class="max-w-5xl mx-auto px-4 py-6">
  <div class="rounded-3xl bg-white border border-slate-200 p-8 card-shadow">
    <h2 class="text-2xl font-bold">Related calculators</h2>
    <p class="mt-3 text-slate-600">{{ relatedIntro or "Use related tools to turn one estimate into a complete financial decision." }}</p>
    <div class="mt-6 grid md:grid-cols-3 gap-4">
      {%- for key in relatedKeys %}
        {%- for c in calculators %}
          {%- if c.key == key %}
      <a href="/{{ c.slug }}.html" class="rounded-2xl border border-slate-200 bg-white p-5 hover:border-emerald-300 hover:text-emerald-700">{{ c.label }}</a>
          {%- endif %}
        {%- endfor %}
      {%- endfor %}
    </div>
  </div>
</section>
