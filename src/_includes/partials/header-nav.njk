{# Header nav — desktop sticky + mobile horizontal scroll. Active link is
   highlighted via the page's `activeKey` frontmatter (matches nav.primary[].key). #}
<div class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <a href="/" class="font-extrabold text-slate-900 text-lg">{{ site.name }}</a>
    <div class="hidden md:flex items-center gap-2 flex-wrap justify-end">
      {%- for item in nav.primary %}
      <a href="{{ item.url }}" class="tab-link shrink-0 px-4 py-3 rounded-full text-sm font-medium {% if item.key == activeKey %}text-emerald-700 bg-emerald-50{% else %}text-slate-700 hover:bg-slate-100{% endif %}">{{ item.label }}</a>
      {%- endfor %}
    </div>
  </div>
  <div class="md:hidden overflow-x-auto whitespace-nowrap scrollbar-hidden px-4 pb-3 flex gap-2">
    {%- for item in nav.primary %}
    <a href="{{ item.url }}" class="tab-link shrink-0 px-4 py-3 rounded-full text-sm font-medium {% if item.key == activeKey %}text-emerald-700 bg-emerald-50{% else %}text-slate-700 hover:bg-slate-100{% endif %}">{{ item.label }}</a>
    {%- endfor %}
  </div>
</div>
