{# Renders one workflow block. Expects `wf` to be set in the calling scope
   to a single workflow object from src/_data/workflows.json. Calculator labels
   are looked up from src/_data/calculators.json by `key`. #}
<article class="bg-white border border-slate-200 rounded-3xl p-8 card-shadow flex flex-col">
  <h3 class="text-2xl font-bold text-slate-900">{{ wf.title }}</h3>
  <p class="mt-3 text-slate-600">{{ wf.tagline }}</p>
  <p class="mt-4 text-sm text-slate-500"><span class="font-semibold text-slate-700">Who it's for:</span> {{ wf.audience }}</p>
  <ol class="mt-5 space-y-2 list-decimal list-inside text-slate-700">
    {%- for key in wf.calculatorKeys %}
      {%- for c in calculators %}
        {%- if c.key == key %}
    <li><a href="/{{ c.slug }}.html" class="text-emerald-700 font-medium hover:text-emerald-800">{{ c.label }}</a></li>
        {%- endif %}
      {%- endfor %}
    {%- endfor %}
  </ol>
  <div class="mt-auto pt-6">
    <a href="{{ wf.primaryCta.url }}" class="inline-flex items-center px-5 py-3 rounded-full bg-emerald-600 text-white font-semibold hover:bg-emerald-700">{{ wf.primaryCta.label }}</a>
  </div>
</article>
