---
layout: layouts/base.njk
---
{# Calculator page intermediate layout. Page frontmatter provides:
     hero          : { h1, leadIn, leadOut?, badges[] }
     calcBody      : raw HTML for the form + result section
     calcScript    : raw JS for the calculator's logic (passed up to base.njk)
     relatedKeys   : [calculator key, ...]
     bodyHtml      : raw HTML for the supporting-copy sections
     authorBoxText : optional override for the "Created by" paragraph
#}

{# --------- Hero --------- #}
<section class="bg-gradient-to-br from-white to-emerald-50 border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 py-14">
    <a href="/" class="text-sm font-medium text-emerald-700">← Back to hub</a>
    <h1 class="mt-4 text-4xl font-black">{{ hero.h1 }}</h1>
    {% if hero.leadIn %}<p class="mt-4 max-w-3xl text-lg text-slate-600">{{ hero.leadIn | safe }}</p>{% endif %}
    {% if hero.leadOut %}<p class="mt-4 max-w-3xl text-slate-600">{{ hero.leadOut | safe }}</p>{% endif %}
    {% if hero.badges %}
    <div class="mt-6 flex flex-wrap gap-3">
      {%- for badge in hero.badges %}
      <span class="rounded-full bg-white px-4 py-2 text-sm font-medium text-slate-700 border border-slate-200">{{ badge }}</span>
      {%- endfor %}
    </div>
    {% endif %}
  </div>
</section>

{# --------- Calculator UI --------- #}
{{ calcBody | safe }}

{# --------- Related calculators --------- #}
{% if relatedKeys %}
  {% include "partials/related-calculators.njk" %}
{% endif %}

{# --------- Supporting copy (why / what / how / scenarios / sources) --------- #}
{{ bodyHtml | safe }}

{# --------- Author trust box --------- #}
<section class="max-w-5xl mx-auto px-4 py-4">
  <div class="rounded-3xl border border-emerald-100 bg-emerald-50 p-8 card-shadow">
    <h2 class="text-2xl font-bold">Created by {{ site.author.name }}</h2>
    {% if authorBoxText %}
    <p class="mt-4 text-slate-700">{{ authorBoxText | safe }}</p>
    {% else %}
    <p class="mt-4 text-slate-700">Finance Tools Hub calculators are maintained by {{ site.author.name }}, whose background includes management, budgeting, compliance, and operational oversight. The site is designed to help users translate gross numbers into more practical planning decisions.</p>
    {% endif %}
    <p class="mt-4 text-slate-700">Last updated: {{ lastUpdated or site.lastUpdated }}.</p>
  </div>
</section>
